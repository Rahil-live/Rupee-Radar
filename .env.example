# ── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (default)
DATABASE_URL=sqlite:///./data/rupee_radar.db
# Production PostgreSQL (Railway injects this automatically via the plugin)
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Add your Vercel production + preview URLs in production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Session TTL ──────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=72

# ── Groq LLM ─────────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
# Leave blank to disable LLM categorisation (rule-based only)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Groq rate limits — defaults match the free tier for llama-3.3-70b-versatile
GROQ_RPM=30
GROQ_TPM=1000
GROQ_RPD=12000
GROQ_TPD=100000

# LLM guard rails (tuned for 1 K TPM free tier)
GROQ_MAX_TOKENS_PER_REQUEST=350
GROQ_MAX_TXNS_PER_UPLOAD=15
GROQ_UPLOAD_TIME_BUDGET_SEC=45
GROQ_MAX_DESCRIPTION_CHARS=48

# ── Frontend (set after Vercel deploy) ───────────────────────────────────────
# VITE_API_URL=https://your-railway-app.up.railway.app
